      { "german": "Wie geht es Ihnen",   "english": "How are you",        "roman": "vee gayt es ee-nen",   "example": "Wie geht es Ihnen?",            "exampleTrans": "How are you? (formal)",         "category": "greeting" },
      { "german": "Mir geht es gut",     "english": "I am fine",          "roman": "meer gayt es goot",    "example": "Mir geht es gut, danke!",       "exampleTrans": "I am fine, thank you!",         "category": "greeting" },
      { "german": "Willkommen",          "english": "Welcome",            "roman": "vil-ko-men",           "example": "Willkommen in Deutschland!",    "exampleTrans": "Welcome to Germany!",           "category": "greeting" }
