      { "german": "Danke",               "english": "Thank you",          "roman": "dahn-keh",             "example": "Danke sehr!",                   "exampleTrans": "Thank you very much!",          "category": "greeting" },
      { "german": "Bitte",               "english": "Please",             "roman": "bit-teh",              "example": "Ein Wasser, bitte.",            "exampleTrans": "A water, please.",              "category": "greeting" },
